# backend/.env

# App
FLASK_ENV=development
SECRET_KEY=your_random_secret_key_here

# Database
DATABASE_URL=postgresql://...          # from NeonDB

# Redis
REDIS_URL=redis://...                  # standard redis:// URL (for Celery broker & rate limiter)
UPSTASH_REDIS_REST_URL=https://...     # from Upstash (REST API, optional)
UPSTASH_REDIS_REST_TOKEN=...           # from Upstash (REST API, optional)

# AI
GROQ_API_KEY=gsk_...                   # from Groq console

# Voice
DEEPGRAM_API_KEY=...                   # from Deepgram
CARTESIA_API_KEY=...                   # from Cartesia
LIVEKIT_URL=wss://...                  # from LiveKit Cloud
LIVEKIT_API_KEY=...                    # from LiveKit Cloud
LIVEKIT_API_SECRET=...                 # from LiveKit Cloud

# Vector DB
QDRANT_URL=https://...                 # from Qdrant Cloud
QDRANT_API_KEY=...                     # from Qdrant Cloud

# File Storage - Backblaze B2
BACKBLAZE_KEY_ID=...              # from Backblaze App Keys
BACKBLAZE_APP_KEY=...             # from Backblaze App Keys
BACKBLAZE_BUCKET_NAME=jarvis-files
BACKBLAZE_BUCKET_ID=...           # from Backblaze bucket settings

# Monitoring
SENTRY_DSN_BACKEND=https://...         # from Sentry